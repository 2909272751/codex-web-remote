# Required. Minimum 8 characters; a longer unique password is recommended.
CODEX_WEB_PASSWORD=replace-with-a-strong-password

# Local HTTP listener. Keep 127.0.0.1 when forwarding through FRP.
CODEX_WEB_HOST=127.0.0.1
CODEX_WEB_PORT=18888

# Set to 1 when the public FRP endpoint is HTTPS and forwards X-Forwarded-Proto.
CODEX_WEB_SECURE_COOKIE=0

# Optional session lifetime in hours (default 12).
CODEX_WEB_SESSION_HOURS=24
